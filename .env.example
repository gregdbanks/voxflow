# === Required ===
# Groq transcription (free tier available at https://console.groq.com).
# Without this key the app falls back to a no-op transcriber useful for
# UI development only.
GROQ_API_KEY=

# === Optional: AWS Bedrock Haiku cleanup ===
# If set, the transcription runs through Haiku 4.5 for punctuation /
# grammar tightening. Leave blank to skip (zero AWS cost).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === Optional: logging ===
LOG_LEVEL=info

# === Optional: hotkey override ===
# Electron Accelerator format. This string registers a secondary toggle
# alongside the primary hold-⌥ behavior.
# VOXFLOW_HOTKEY=Command+Alt+Z
