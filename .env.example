# VoxFlow is fully local by default. None of these values are required.

# === Optional: cloud transcription fallback ===
# If you want to fall back to Groq Whisper (e.g. before the local model
# has finished downloading), set GROQ_API_KEY and VOXFLOW_TRANSCRIPTION_PROVIDER=groq.
# Audio WILL be uploaded to api.groq.com when this is active. The app
# shows an orange "Cloud" badge in the popover so it's always visible.
GROQ_API_KEY=
# VOXFLOW_TRANSCRIPTION_PROVIDER=local    # local (default) | groq | none

# Local Whisper model to load. Default: large-v3-turbo (~1.5GB, best
# accuracy-to-speed ratio on Apple Silicon). Options:
# tiny.en base.en small.en medium.en large-v3-turbo large-v3
# VOXFLOW_WHISPER_MODEL=large-v3-turbo

# === Optional: logging ===
LOG_LEVEL=info

# === Optional: hotkey override (Electron Accelerator format) ===
# VOXFLOW_HOTKEY=Command+Alt+Z
