# VoxFlow is fully local. No API keys required.
# Everything below is an optional developer override.

# Log verbosity — debug | info (default) | warn | error
# LOG_LEVEL=info

# Global hotkey (Electron Accelerator format). Bare-⌥ press-and-hold is
# the primary trigger via uiohook-napi; this shortcut is a secondary
# toggle fallback registered in parallel.
# VOXFLOW_HOTKEY=Command+Alt+Z

# Local Whisper model. Default: large-v3-turbo (~1.5GB, best
# accuracy-to-speed on Apple Silicon). Options:
# tiny.en base.en small.en medium.en large-v3-turbo large-v3
# VOXFLOW_WHISPER_MODEL=large-v3-turbo
