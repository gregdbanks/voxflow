{
  "name": "voxflow",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first macOS voice dictation — hold Option, talk, paste. Free alternative to Wispr Flow.",
  "keywords": [
    "dictation",
    "voice",
    "whisper",
    "groq",
    "electron",
    "macos",
    "menubar"
  ],
  "homepage": "https://github.com/gregdbanks/voxflow#readme",
  "bugs": {
    "url": "https://github.com/gregdbanks/voxflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gregdbanks/voxflow.git"
  },
  "license": "MIT",
  "author": {
    "name": "Greg Banks",
    "url": "https://github.com/gregdbanks"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "prestart": "npm run rebuild:native && npm run build:helpers",
    "package": "electron-forge package",
    "prepackage": "npm run rebuild:native && npm run build:helpers",
    "build:paste-helper": "mkdir -p native/build && clang -O2 -framework ApplicationServices -o native/build/paste-helper native/paste-helper.c && codesign --sign - --identifier com.voxflow.paste-helper --force native/build/paste-helper",
    "build:key-listener": "mkdir -p native/build && clang -O2 -framework ApplicationServices -framework CoreFoundation -o native/build/key-listener native/key-listener.c && codesign --sign - --identifier com.voxflow.key-listener --force native/build/key-listener",
    "build:helpers": "npm run build:paste-helper && npm run build:key-listener",
    "make": "electron-forge make",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "npm run rebuild:native",
    "test:e2e": "playwright test",
    "screenshots:m1": "tsx scripts/capture-m1-screenshots.ts",
    "screenshots:m2": "tsx scripts/capture-m2-screenshots.ts",
    "screenshots:m3": "tsx scripts/capture-m3-screenshots.ts",
    "screenshots:m4": "tsx scripts/capture-m4-screenshots.ts",
    "screenshots:m5": "tsx scripts/capture-m5-screenshots.ts",
    "test:integration": "VOXFLOW_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,uiohook-napi,robotjs,smart-whisper",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1036.0",
    "@paymoapp/active-window": "^2.1.4",
    "better-sqlite3": "^12.9.0",
    "clipboardy": "^5.3.1",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "fastest-levenshtein": "^1.0.16",
    "menubar": "^9.5.1",
    "msw": "^2.13.5",
    "node-mic": "^1.0.1",
    "openai": "^6.34.0",
    "robotjs": "^0.7.0",
    "smart-whisper": "^0.8.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.5.0",
    "@electron-forge/plugin-fuses": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^33.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "playwright": "^1.49.0",
    "prettier": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
